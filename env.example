# Configuration de l'environnement
NODE_ENV=production

# Configuration de la base de données
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=tontine
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Configuration JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=365d

# Configuration des mots de passe
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=100
DEFAULT_PASSWORD=changeme1@

# Configuration Sentry
SENTRY_ENABLED=true
SENTRY_DSN=your-sentry-dsn-here
SENTRY_DEBUG=false
SENTRY_RELEASE=production

# Configuration Resend (Email)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Configuration pour réinitialisation de mot de passe
# URL de l'application externe pour la réinitialisation (l'utilisateur sera redirigé vers cette URL avec le token)
PASSWORD_RESET_URL=https://yourdomain.com/reset-password