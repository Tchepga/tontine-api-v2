# Configuration de l'environnement
NODE_ENV=production

# Docker Compose — MySQL (obligatoire pour `docker compose up` : pas de secrets dans le YAML)
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=tontine
MYSQL_USER=tontine
MYSQL_PASSWORD=change-me-app

# Configuration de la base de données (API Nest)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=tontine
DB_PASSWORD=change-me-app
DB_DATABASE=tontine
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Configuration JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=365d

# Configuration des mots de passe
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=100
DEFAULT_PASSWORD=changeme1@

# Configuration Sentry
SENTRY_ENABLED=true
SENTRY_DSN=your-sentry-dsn-here
SENTRY_DEBUG=false
SENTRY_RELEASE=production

# Configuration Resend (Email)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Réinitialisation mot de passe — URLs sensibles (définir en .env / secrets CI, ne pas committer les vraies valeurs)
# Lien dans les e-mails (souvent page web ou deep link)
PASSWORD_RESET_URL=https://yourdomain.com/reset-password
# Deep link pour ouvrir l’app mobile (ex. myapp://) — traiter comme secret (identifiant de scheme / marque)
MOBILE_DEEP_LINK_SCHEME=myapp
# Page web de secours si l’app n’est pas installée (token dans l’URL)
WEB_RESET_URL=https://yourdomain.com/reset-password