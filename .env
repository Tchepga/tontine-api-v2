# Configuration JWT
JWT_SECRET=votre-secret-jwt-super-securise
JWT_EXPIRES_IN=24h

# Configuration Base de données
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=tontine
DB_PASSWORD=tontine
DB_DATABASE=tontine
DB_SYNCHRONIZE=false

# Configuration Mots de passe
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=100
DEFAULT_PASSWORD=changeme1@

# Environnement
NODE_ENV=production
