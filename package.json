{
  "name": "tontine-api-v2",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testPathPattern=src --testNamePattern='\\.spec\\.ts$'",
    "test:integration": "jest --testPathPattern=test --testNamePattern='\\.e2e-spec\\.ts$'",
    "test:ci": "jest --ci --coverage --watchAll=false --verbose",
    "test:validate": "./scripts/test-validation.sh",
    "test:working": "jest --testPathPattern='(app|tontine)' --testNamePattern='\\.spec\\.ts$'",
    "build:prod": "npm run lint && npm run test:cov && nest build",
    "start:prod:sentry": "npm run build:prod && node dist/main.js",
    "start:sentry": "./scripts/deploy/start-sentry.sh",
    "start:dev:sentry": "./scripts/deploy/start-dev.sh",
    "deploy:sentry": "./scripts/deploy/deploy-simple.sh",
    "deploy:robust": "./scripts/deploy/deploy-robust.sh",
    "deploy:simple": "./scripts/deploy/deploy-simple.sh",
    "test:deployment": "./scripts/deploy/test-deployment.sh",
    "process:status": "./scripts/deploy/manage-processes.sh status",
    "process:stop": "./scripts/deploy/manage-processes.sh stop",
    "process:restart": "./scripts/deploy/manage-processes.sh restart",
    "process:logs": "./scripts/deploy/manage-processes.sh logs",
    "process:pid": "./scripts/deploy/manage-processes.sh pid",
    "cleanup": "./scripts/deploy/cleanup.sh"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-fastify": "^10.4.6",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.15",
    "@sentry/node": "^10.17.0",
    "@sentry/profiling-node": "^10.17.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify-file-interceptor": "^1.0.9",
    "mysql2": "^3.11.3",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "tontine-api-v2": "file:",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@sentry/cli": "^2.53.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
