{
  "name": "tontine-api-v2",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testPathPattern=src --testNamePattern='\\.spec\\.ts$'",
    "test:integration": "jest --testPathPattern=test --testNamePattern='\\.e2e-spec\\.ts$'",
    "test:ci": "jest --ci --coverage --watchAll=false --verbose",
    "test:validate": "./scripts/test-validation.sh",
    "test:working": "jest --testPathPattern='(app|tontine)' --testNamePattern='\\.spec\\.ts$'",
    "build:prod": "npm run lint && npm run test:cov && nest build",
    "start:prod:sentry": "npm run build:prod && node dist/main.js",
    "start:sentry": "./scripts/deploy/start-sentry.sh",
    "start:dev:sentry": "./scripts/deploy/start-dev.sh",
    "deploy:sentry": "./scripts/deploy/deploy-simple.sh",
    "deploy:robust": "./scripts/deploy/deploy-robust.sh",
    "deploy:simple": "./scripts/deploy/deploy-simple.sh",
    "test:deployment": "./scripts/deploy/test-deployment.sh",
    "process:status": "./scripts/deploy/manage-processes.sh status",
    "process:stop": "./scripts/deploy/manage-processes.sh stop",
    "process:restart": "./scripts/deploy/manage-processes.sh restart",
    "process:logs": "./scripts/deploy/manage-processes.sh logs",
    "process:pid": "./scripts/deploy/manage-processes.sh pid",
    "cleanup": "./scripts/deploy/cleanup.sh",
    "check:database": "node --experimental-modules scripts/check-database.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f mysql",
    "docker:restart": "docker-compose restart mysql"
  },
  "dependencies": {
    "@fastify/static": "^9.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-fastify": "^11.0.20",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.3.2",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "@sentry/node": "^10.17.0",
    "@sentry/profiling-node": "^10.17.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "fastify-file-interceptor": "^1.0.9",
    "mysql2": "^3.22.1",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.12.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@sentry/cli": "^2.58.5",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.5.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
